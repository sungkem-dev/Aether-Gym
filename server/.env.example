# =============================================================================
# AETHERGYM SUITE — BACKEND ENVIRONMENT VARIABLES
# =============================================================================
# COPY this file to .env and fill in your values.
# NEVER commit .env to git (it's in .gitignore).
# =============================================================================

# --- Server ---
PORT=3001
# The URL of your frontend (for CORS whitelist)
FRONTEND_URL=http://localhost:5173

# --- Supabase ---
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
# Use the SERVICE ROLE key (not the anon key) for server-side operations.
# WARNING: This key bypasses RLS. Keep it secret and server-side only.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- LogMeal API ---
# Sign up at: https://app.logmeal.com/
# Get your API token from: Dashboard > API Keys
# Endpoint used: POST https://api.logmeal.com/v2/image/segmentation/complete
LOGMEAL_API_TOKEN=your_logmeal_api_token_here

# --- Midtrans Payment Gateway ---
# Sign up at: https://dashboard.midtrans.com/
# Get keys from: Settings > Access Keys
# For sandbox testing, use Sandbox keys (prefix: SB-Mid-)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
# Set to 'true' in production, 'false' for sandbox
MIDTRANS_IS_PRODUCTION=false

# --- Supabase Storage ---
# Name of the storage bucket for food images (must exist in Supabase Storage)
SUPABASE_STORAGE_BUCKET=food-images
